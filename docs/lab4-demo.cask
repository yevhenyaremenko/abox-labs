[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No AgentgatewayPolicy with JWT authentication was found. All MCP endpoints are unauthenticated.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"AUTH-002\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Any client can access MCP tools without presenting valid credentials.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Create an AgentgatewayPolicy with traffic.jwtAuthentication targeting your Gateway or HTTPRoutes.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Critical\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"timestamp\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"2026-05-24T07:59:29Z\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No JWT authentication configured\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"CORS\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No AgentgatewayPolicy or HTTPRoute with CORS configuration was found. MCP endpoints may be vulnerable to cross-origin attacks.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"CORS-001\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Browser-based MCP clients may be susceptible to cross-site request forgery.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add a CORS filter to your HTTPRoute or create an AgentgatewayPolicy with traffic.cors configuration.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"timestamp\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"2026-05-24T07:59:29Z\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No CORS policy configured for MCP endpoints\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Exposure\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer 'kagent/kagent-tool-server' has URL 'http://kagent-tools.kagent:8084/mcp' which does not point to agentgateway. MCP traffic should be routed through agentgateway for governance enforcement.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"EXP-001-kagent-tool-server\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"MCP tool calls bypass agentgateway governance — no authentication, authorization, or rate limiting is applied.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Update the RemoteMCPServer URL to point to the agentgateway service endpoint (e.g., http://agentgateway.agentgateway-system:8080/mcp/<backend-name>/<target>).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer/kagent/kagent-tool-server\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"timestamp\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"2026-05-24T07:59:29Z\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer 'kagent-tool-server' not routed through agentgateway\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ToolScope\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer 'kagent/kagent-tool-server' has 123 discovered tools, exceeding the critical threshold of 15. Excessive tool exposure increases the attack surface and makes authorization harder to manage.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"TOOLS-001-kagent-tool-server\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Large tool surface increases risk of unauthorized tool invocation, prompt injection via tool descriptions, and makes least-privilege access control impractical.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Split the MCP server into smaller, focused servers with fewer tools. Consider using toolNames in agent tool references to limit exposed tools to only those needed. Target: ≤15 tools per server.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer/kagent/kagent-tool-server\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Critical\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"timestamp\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"2026-05-24T07:59:29Z\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"RemoteMCPServer 'kagent-tool-server' exposes 123 tools (threshold: 15)\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'kagent/kagent-tools' do not set runAsNonRoot:true or a non-zero runAsUser. Containers running as root are a critical security risk.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-001-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A compromised container process runs with UID 0, giving it full access to the host filesystem and ability to escape the container.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add securityContext.runAsNonRoot: true and securityContext.runAsUser: <non-zero> to every container spec in the workload.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Critical\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' has containers running as root\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'kagent/kagent-tools' do not set readOnlyRootFilesystem:true.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-002-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A writable root filesystem allows an attacker to modify binaries, drop malicious files, or persist backdoors inside the container.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set securityContext.readOnlyRootFilesystem: true on every container. Mount writable paths (tmp, cache) as emptyDir volumes.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' does not enforce read-only root filesystem\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'kagent/kagent-tools' do not set allowPrivilegeEscalation:false.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-003-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A process inside the container can gain elevated privileges via setuid binaries, sudo, or kernel exploits.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set securityContext.allowPrivilegeEscalation: false on every container spec.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' allows privilege escalation\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'kagent/kagent-tools' do not set capabilities.drop: [ALL].\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-004-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Unnecessary Linux capabilities increase the blast radius if a container is compromised.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add securityContext.capabilities.drop: [ALL] to every container spec. Add only specifically required capabilities via capabilities.add.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' does not drop all Linux capabilities\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent/kagent-tools' does not configure a seccomp profile (RuntimeDefault or Localhost).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-005-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without seccomp, containers can make any Linux syscall, increasing the kernel attack surface.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' has no seccomp profile\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent/kagent-tools' sets env vars with names matching secret patterns (KEY, TOKEN, SECRET, PASSWORD, CREDENTIAL) using a plain value: field instead of valueFrom.secretKeyRef.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-008-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Secrets embedded as plain env var values are exposed in pod specs, etcd, and any tooling that dumps pod manifests.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Replace plaintext env var values with valueFrom.secretKeyRef referencing a Kubernetes Secret, or use a Vault agent / External Secrets Operator to inject secrets.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' has plaintext secret env vars: [TOKEN_PASSTHROUGH]\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent/kagent-tools' has neither vault.hashicorp.com/agent-inject nor a secrets-store.csi.x-k8s.io annotation. Secrets may be sourced from plain Kubernetes Secrets or env vars.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-009-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Kubernetes Secrets are only base64-encoded and are not encrypted at rest by default. A proper secret store provides encryption, rotation, and audit trails.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent/kagent-tools' does not carry a Cosign/Sigstore image signature annotation (cosign.sigstore.dev/imageRef). Image provenance cannot be verified.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-010-kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without signature verification, tampered or substituted images can be deployed without detection.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"kagent\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/kagent/kagent-tools\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'kagent-tools' has no image signature annotation\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "      \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"grade\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"F\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasAuth\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasCORS\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "      \u001b[0m\u001b[1;34m\"hasJWT\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasPromptGuard\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasRBAC\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasRateLimit\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "      \u001b[0m\u001b[1;34m\"hasTLS\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"hasToolRestriction\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n"]
