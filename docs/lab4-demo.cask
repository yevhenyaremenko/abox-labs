[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"CORS\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No AgentgatewayPolicy or HTTPRoute with CORS configuration was found. MCP endpoints may be vulnerable to cross-origin attacks.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"CORS-001\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Browser-based MCP clients may be susceptible to cross-site request forgery.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add a CORS filter to your HTTPRoute or create an AgentgatewayPolicy with traffic.cors configuration.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"timestamp\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"2026-05-24T07:59:29Z\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No CORS policy configured for MCP endpoints\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'agentgateway-system/agentgateway' do not set runAsNonRoot:true or a non-zero runAsUser. Containers running as root are a critical security risk.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-001-agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A compromised container process runs with UID 0, giving it full access to the host filesystem and ability to escape the container.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add securityContext.runAsNonRoot: true and securityContext.runAsUser: <non-zero> to every container spec in the workload.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Critical\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' has containers running as root\"\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'agentgateway-system/agentgateway' do not set readOnlyRootFilesystem:true.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-002-agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A writable root filesystem allows an attacker to modify binaries, drop malicious files, or persist backdoors inside the container.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set securityContext.readOnlyRootFilesystem: true on every container. Mount writable paths (tmp, cache) as emptyDir volumes.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' does not enforce read-only root filesystem\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'agentgateway-system/agentgateway' do not set allowPrivilegeEscalation:false.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-003-agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A process inside the container can gain elevated privileges via setuid binaries, sudo, or kernel exploits.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set securityContext.allowPrivilegeEscalation: false on every container spec.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"High\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' allows privilege escalation\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"One or more containers in Deployment 'agentgateway-system/agentgateway' do not set capabilities.drop: [ALL].\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-004-agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Unnecessary Linux capabilities increase the blast radius if a container is compromised.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Add securityContext.capabilities.drop: [ALL] to every container spec. Add only specifically required capabilities via capabilities.add.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' does not drop all Linux capabilities\"\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway' does not configure a seccomp profile (RuntimeDefault or Localhost).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-005-agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without seccomp, containers can make any Linux syscall, increasing the kernel attack surface.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' has no seccomp profile\"\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Namespace 'agentgateway-system' has no NetworkPolicy with ingress or egress rules. All pods in this namespace can communicate freely with any other pod in the cluster.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-007-agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"A compromised MCP server container can reach any internal service, database, or cloud metadata endpoint without restriction.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Create a NetworkPolicy in namespace '%s' with an ingress rule allowing only agentgateway traffic and a restrictive egress rule.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Critical\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No NetworkPolicy in namespace 'agentgateway-system'\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway' has neither vault.hashicorp.com/agent-inject nor a secrets-store.csi.x-k8s.io annotation. Secrets may be sourced from plain Kubernetes Secrets or env vars.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-009-agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Kubernetes Secrets are only base64-encoded and are not encrypted at rest by default. A proper secret store provides encryption, rotation, and audit trails.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway' does not carry a Cosign/Sigstore image signature annotation (cosign.sigstore.dev/imageRef). Image provenance cannot be verified.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-010-agentgateway\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without signature verification, tampered or substituted images can be deployed without detection.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway' has no image signature annotation\"\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway-external' does not configure a seccomp profile (RuntimeDefault or Localhost).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-005-agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without seccomp, containers can make any Linux syscall, increasing the kernel attack surface.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-external' has no seccomp profile\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway-external' has neither vault.hashicorp.com/agent-inject nor a secrets-store.csi.x-k8s.io annotation. Secrets may be sourced from plain Kubernetes Secrets or env vars.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-009-agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Kubernetes Secrets are only base64-encoded and are not encrypted at rest by default. A proper secret store provides encryption, rotation, and audit trails.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"severity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Medium\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"title\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-external' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n        \u001b[1;39m{\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardening\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment 'agentgateway-system/agentgateway-external' does not carry a Cosign/Sigstore image signature annotation (cosign.sigstore.dev/imageRef). Image provenance cannot be verified.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"HDN-010-agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"impact\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Without signature verification, tampered or substituted images can be deployed without detection.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"namespace\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"agentgateway-system\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"remediation\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"resourceRef\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Deployment/agentgateway-system/agentgateway-external\"\u001b[0m\u001b[1;39m,\r\n"]
