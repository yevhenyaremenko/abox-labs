[0.000, "o", "          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardened Deployment\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"maxScore\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m100\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"reasons\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Critical] Deployment 'agentgateway' has containers running as root\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[High] Deployment 'agentgateway' does not enforce read-only root filesystem\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[High] Deployment 'agentgateway' allows privilege escalation\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway' does not drop all Linux capabilities\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'agentgateway' has no seccomp profile\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Critical] No NetworkPolicy in namespace 'agentgateway-system'\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway' has no image signature annotation\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'agentgateway-external' has no seccomp profile\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'agentgateway-external' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway-external' has no image signature annotation\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway' has no seccomp profile\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'agentgateway' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'agentgateway' has no image signature annotation\"\u001b[0m\u001b[1;39m\r\n          \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"score\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m0\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"sources\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;90mnull\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"fail\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"suggestions\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "            \u001b[0;32m\"Add securityContext.runAsNonRoot: true and securityContext.runAsUser: <non-zero> to every container spec in the workload.\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Set securityContext.readOnlyRootFilesystem: true on every container. Mount writable paths (tmp, cache) as emptyDir volumes.\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Set securityContext.allowPrivilegeEscalation: false on every container spec.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Add securityContext.capabilities.drop: [ALL] to every container spec. Add only specifically required capabilities via capabilities.add.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Create a NetworkPolicy in namespace '%s' with an ingress rule allowing only agentgateway traffic and a restrictive egress rule.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m\r\n          \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n        \u001b[1;39m}\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n"]
