[0.000, "o", "          \u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"fail\"\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"suggestions\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n            \u001b[0;32m\"Add traffic.cors to an AgentgatewayPolicy or add a CORS filter to the HTTPRoute.\"\u001b[0m\u001b[1;39m\r\n"]
