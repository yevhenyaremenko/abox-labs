[0.000, "o", "\r\r\u001b[A\u001b[0m\u001b[27m\u001b[24m\u001b[J\u001b[0m\u001b[49m\u001b[27m\u001b[24m\u001b[38;5;76m❯\u001b[0m\u001b[38;5;76m\u001b[49m\u001b[39m\u001b[27m\u001b[24m \u001b[32mmake\u001b[39m help\u001b[K\u001b[?12l\u001b[?25h"]
[0.000, "o", "\r\r\n"]
[0.001, "o", "\u001b]2;make help\u0007\u001b]1;make\u0007"]
[0.327, "o", "Available targets:\r\n"]
[0.014, "o", "  run     - Bootstrap the full environment (install tools, provision cluster)\r\n"]
[0.014, "o", "  down    - Destroy the cluster and all resources\r\n"]
[0.013, "o", "  push    - Bump patch version, tag, and push to trigger CI\r\n"]
[0.014, "o", "  tools   - Install necessary tools only\r\n"]
[0.013, "o", "  tofu    - Initialize OpenTofu\r\n"]
[0.014, "o", "  apply   - Apply OpenTofu configuration and create secrets\r\n"]
[0.014, "o", "  secrets                      - Create openai-secret from OPENAI_API_KEY and github-mcp-secret from GITHUB_TOKEN\r\n"]
[0.014, "o", "  test-api                     - Run all API checks (OpenAI direct + via agentgateway)\r\n"]
[0.014, "o", "  test-openai                  - Run all OpenAI checks (direct + via agentgateway)\r\n"]
[0.014, "o", "  test-openai-direct           - Curl OpenAI API directly (requires OPENAI_API_KEY)\r\n"]
[0.014, "o", "  test-openai-via-agentgateway - Curl OpenAI via agentgateway (port-forward auto)\r\n"]
[0.015, "o", "  a2a-agent-card [agent]       - Fetch Agent Card(s) via Well-Known URI (A2A, port-forward auto)\r\n"]
[0.014, "o", "                                 no arg: fetches aire-agent, github-agent, conductor-agent\r\n"]
[0.014, "o", "                                 agent: fetch a single card, e.g. make a2a-agent-card github-agent\r\n"]
[0.013, "o", "  inventory-agents             - List AI agents discovered by agentregistry-inventory (port-forward auto)\r\n"]
[0.014, "o", "  inventory-servers            - List MCP servers discovered by agentregistry-inventory (port-forward auto)\r\n"]
[0.014, "o", "  governance-score             - Fetch MCPG overall governance score (port-forward auto)\r\n"]
[0.013, "o", "  governance-servers           - Fetch MCPG per-MCP-server security findings (port-forward auto)\r\n"]
[0.014, "o", "  governance-ui                - Open MCPG dashboard in browser (port-forward auto)\r\n"]
[0.013, "o", "  qdrant-info                  - Show Qdrant cluster info (port-forward auto)\r\n"]
[0.015, "o", "  qdrant-collections           - List Qdrant collections (port-forward auto)\r\n"]
[0.002, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                                                                                                                                                     \r \r"]
