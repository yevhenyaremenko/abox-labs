[0.000, "o", "        \u001b[1;39m{\r\n          \u001b[0m\u001b[1;34m\"category\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Hardened Deployment\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"maxScore\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m100\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"reasons\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Critical] Deployment 'github-mcp-server' has containers running as root\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[High] Deployment 'github-mcp-server' does not enforce read-only root filesystem\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[High] Deployment 'github-mcp-server' allows privilege escalation\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'github-mcp-server' does not drop all Linux capabilities\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'github-mcp-server' has no seccomp profile\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'github-mcp-server' uses :latest or untagged container image\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"[Medium] Deployment 'github-mcp-server' does not use a secret store (Vault/ESO)\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"[Medium] Deployment 'github-mcp-server' has no image signature annotation\"\u001b[0m\u001b[1;39m\r\n          \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"score\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m0\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"sources\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;90mnull\u001b[0m\u001b[1;39m,\r\n          \u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"fail\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "          \u001b[0m\u001b[1;34m\"suggestions\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "            \u001b[0;32m\"Add securityContext.runAsNonRoot: true and securityContext.runAsUser: <non-zero> to every container spec in the workload.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.001, "o", "            \u001b[0;32m\"Set securityContext.readOnlyRootFilesystem: true on every container. Mount writable paths (tmp, cache) as emptyDir volumes.\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Set securityContext.allowPrivilegeEscalation: false on every container spec.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Add securityContext.capabilities.drop: [ALL] to every container spec. Add only specifically required capabilities via capabilities.add.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Set pod spec securityContext.seccompProfile.type: RuntimeDefault (or Localhost with a custom profile).\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Pin all container images to a specific immutable digest (sha256:...) or a versioned tag. Never use :latest in production.\"\u001b[0m\u001b[1;39m,\r\n            \u001b[0;32m\"Integrate Vault Agent Injector or External Secrets Operator and annotate pods with vault.hashicorp.com/agent-inject: 'true' to inject secrets from a vault.\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "            \u001b[0;32m\"Sign container images with Cosign (cosign sign <image>) and enforce signature verification via a Kubernetes admission policy (e.g., Kyverno or OPA Gatekeeper).\"\u001b[0m\u001b[1;39m\r\n          \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "        \u001b[1;39m}\u001b[0m\u001b[1;39m\r\n"]
