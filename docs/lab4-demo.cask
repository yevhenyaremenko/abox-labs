[2.283, "o", "\u001b[0;32m[PASS]\u001b[0m github-agent (HTTP 200)\r\n\u001b[0;36mAgent Card [github-agent]:\u001b[0m\r\n"]
[0.020, "o", "\u001b[1;39m{\r\n"]
[0.000, "o", "  \u001b[0m\u001b[1;34m\"capabilities\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m{\r\n"]
[0.000, "o", "    \u001b[0m\u001b[1;34m\"pushNotifications\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "    \u001b[0m\u001b[1;34m\"stateTransitionHistory\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mtrue\u001b[0m\u001b[1;39m,\r\n    \u001b[0m\u001b[1;34m\"streaming\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mtrue\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "  \u001b[0m\u001b[1;34m\"defaultInputModes\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[0;32m\"text\"\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"defaultOutputModes\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "    \u001b[0;32m\"text\"\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"GitHub operations agent — manages repositories, branches, pull requests and file content via MCP.\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"github_agent\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"skills\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Search for code, files, or symbols across GitHub repositories.\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"examples\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;32m\"Search for Deployment manifests that set replicas > 3\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "        \u001b[0;32m\"Find all usages of the old API endpoint in the codebase\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"github-search\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Code Search\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"tags\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n"]
[0.000, "o", "        \u001b[0;32m\"github\"\u001b[0m\u001b[1;39m,\r\n        \u001b[0;32m\"search\"\u001b[0m\u001b[1;39m,\r\n        \u001b[0;32m\"code\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n    \u001b[1;39m{\r\n"]
